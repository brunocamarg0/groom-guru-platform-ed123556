# Mercado Pago Configuration
# Get credentials at: https://www.mercadopago.com.br/developers/panel/credentials
# NEVER commit real tokens. Use placeholder values only.

VITE_MERCADOPAGO_ACCESS_TOKEN=TEST-your-test-token-here
MERCADOPAGO_ACCESS_TOKEN=TEST-your-test-token-here

# For production, set APP_USR-... tokens in your hosting provider's secrets,
# never in this file or any committed file.

# ============================================
# OAuth Configuration
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL_CLIENTE=http://localhost:3001/api/auth/google/cliente/callback
GOOGLE_CALLBACK_URL_DONO=http://localhost:3001/api/auth/google/dono/callback

FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL_CLIENTE=http://localhost:3001/api/auth/facebook/cliente/callback
FACEBOOK_CALLBACK_URL_DONO=http://localhost:3001/api/auth/facebook/dono/callback

APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key
APPLE_CALLBACK_URL_CLIENTE=http://localhost:3001/api/auth/apple/cliente/callback
APPLE_CALLBACK_URL_DONO=http://localhost:3001/api/auth/apple/dono/callback
