# Mercado Pago Configuration - Barber Payments
# Integração: Checkout Transparente
# Obtenha suas credenciais em: https://www.mercadopago.com.br/developers/panel/credentials

# Access Token de TESTE (para desenvolvimento - não debita valores reais)
VITE_MERCADOPAGO_ACCESS_TOKEN=TEST-d450f022-fc2f-4ae2-8629-e5f723e5cf86

# Access Token para Serverless Functions (Vercel)
MERCADOPAGO_ACCESS_TOKEN=TEST-d450f022-fc2f-4ae2-8629-e5f723e5cf86

# Access Token de PRODUÇÃO (descomente quando estiver pronto para produção)
