// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Usuário Admin do sistema
model UsuarioAdmin {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  role      String   @default("admin") // admin, super_admin
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Plano de assinatura
model Plano {
  id                String      @id @default(uuid())
  nome              String      // Básico, Premium, Enterprise
  descricao         String?
  valorMensal       Float
  limiteBarbeiros   Int         @default(1)
  limiteAgendamentos Int        @default(100)
  recursos          String[]    @default([]) // Array de recursos disponíveis
  ativo             Boolean     @default(true)
  
  assinaturas       Assinatura[]
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

// Barbearia cadastrada no sistema
model Barbearia {
  id                String    @id @default(uuid())
  nome              String
  cnpjCpf           String
  responsavel       String    // Nome do responsável legal
  plano             String    // basico, premium, enterprise (mantido para compatibilidade)
  status            String    @default("em_teste") // ativa, em_teste, bloqueada, cancelada
  dataCriacao       DateTime  @default(now())
  dataVencimento    DateTime  // Mantido para compatibilidade
  email             String?
  telefone          String?
  endereco          String?
  cidade            String?
  bairro            String?
  cep               String?
  modoConfirmacao   String   @default("hibrido") // automatico, manual, hibrido
  foto              String?  // URL ou base64 da foto da barbearia
  latitude          Float?   // Coordenada para mapa
  longitude         Float?   // Coordenada para mapa
  
  // Relacionamentos
  dono              UsuarioDono?  @relation("BarbeariaDono")
  assinatura        Assinatura?   // Assinatura ativa
  convites          Convite[]
  servicos          Servico[]
  agendamentos      Agendamento[]
  solicitacao       SolicitacaoCadastro? @relation("SolicitacaoBarbearia")
  profissionais    Profissional[]
  produtos          Produto[]
  promocoes         Promocao[]
  notificacoes      Notificacao[]
  comissoes         ComissaoPaga[]
  planosCliente     PlanoCliente[]
  comissoesAssinatura ComissaoAssinatura[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// Assinatura da barbearia
model Assinatura {
  id                String      @id @default(uuid())
  barbearia         Barbearia   @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  barbeariaId       String      @unique
  plano             Plano       @relation(fields: [planoId], references: [id])
  planoId           String
  
  status            String      @default("ativa") // ativa, suspensa, cancelada, vencida
  dataInicio        DateTime    @default(now())
  dataVencimento    DateTime
  proximoVencimento DateTime
  
  // Pagamento recorrente
  pagamentoRecorrente Boolean   @default(false) // Se tem pagamento automático configurado
  mercadoPagoSubscriptionId String? // ID da assinatura no Mercado Pago
  
  faturas            Fatura[]
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

// Fatura mensal da assinatura
model Fatura {
  id                String      @id @default(uuid())
  assinatura        Assinatura  @relation(fields: [assinaturaId], references: [id], onDelete: Cascade)
  assinaturaId      String
  
  valor             Float
  dataVencimento    DateTime
  dataPagamento     DateTime?
  status            String      @default("pendente") // pendente, paga, vencida, cancelada
  
  // Integração com gateway
  metodoPagamento   String?     // pix, boleto, cartao_credito, cartao_debito
  mercadoPagoPreferenceId String? // ID da preferência no Mercado Pago
  mercadoPagoPaymentId    String? // ID do pagamento quando aprovado
  mercadoPagoStatus       String? // approved, pending, rejected
  
  // Dados do pagamento
  linkPagamento     String?     // Link para pagar a fatura
  qrCodePix         String?     // QR Code PIX (base64)
  codigoBoleto      String?     // Código de barras do boleto
  
  observacoes       String?
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  @@index([assinaturaId, status])
  @@index([dataVencimento])
}

// Usuário Dono da barbearia (criado via convite)
model UsuarioDono {
  id          String     @id @default(uuid())
  nome        String
  email       String     @unique
  senha       String?    // Hash da senha (opcional se usar OAuth)
  googleId    String?    @unique // ID do Google OAuth
  foto        String?    // Foto do perfil Google
  ativo       Boolean    @default(true)
  emailVerificado Boolean @default(false)
  
  // Relacionamento com barbearia
  barbeariaId String     @unique
  barbearia   Barbearia  @relation("BarbeariaDono", fields: [barbeariaId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// Convite para ativação de conta do dono
model Convite {
  id          String   @id @default(uuid())
  token       String   @unique // Token único para o link de ativação
  email       String?   // Email para onde foi enviado (opcional)
  expiraEm    DateTime  // Data de expiração do convite
  usado       Boolean   @default(false) // Se já foi usado
  usadoEm     DateTime?
  
  // Relacionamento com barbearia
  barbeariaId String
  barbearia   Barbearia @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Solicitação de cadastro de nova barbearia (pendente de aprovação do admin)
model SolicitacaoCadastro {
  id          String   @id @default(uuid())
  nome        String   // Nome da barbearia
  cnpjCpf     String   // CNPJ ou CPF
  responsavel String   // Nome do responsável
  email       String   // Email do responsável (onde será enviada a senha)
  telefone    String?
  endereco    String?
  plano       String   @default("basico") // basico, premium, enterprise
  status      String   @default("pendente") // pendente, aprovada, rejeitada
  observacoes String?  // Observações do admin
  
  // Relacionamento com barbearia (após aprovação)
  barbeariaId String?  @unique
  barbearia   Barbearia? @relation("SolicitacaoBarbearia", fields: [barbeariaId], references: [id], onDelete: SetNull)
  
  aprovadaEm  DateTime?
  aprovadaPor String?  // ID do admin que aprovou
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Servico {
  id          String   @id @default(uuid())
  nome        String
  descricao   String?
  preco       Float
  duracao     Int      // em minutos
  tipo        String?  // corte, barba, combo, etc
  ativo       Boolean  @default(true)
  ordem       Int      @default(0)
  
  barbearia   Barbearia @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  barbeariaId String
  
  // Relação inversa com Agendamento
  agendamentos Agendamento[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Cliente cadastrado no sistema
model Cliente {
  id          String        @id @default(uuid())
  nome        String
  email       String        @unique
  senha       String?       // Hash da senha (opcional se usar OAuth)
  googleId    String?       @unique // ID do Google OAuth
  facebookId  String?       @unique // ID do Facebook OAuth
  appleId     String?       @unique // ID do Apple OAuth
  telefone    String?
  foto        String?       // Foto do perfil OAuth
  dataNascimento DateTime?
  ativo       Boolean       @default(true)
  emailVerificado Boolean   @default(true) // Google já verifica email
  
  // Relacionamentos
  agendamentos Agendamento[]
  avaliacoes   Avaliacao[]
  tickets      TicketSuporte[]
  assinatura   AssinaturaCliente?
  clienteProfissional ClienteProfissional[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Agendamento {
  id          String   @id @default(uuid())
  cliente     String   // Nome do cliente (mantido para compatibilidade)
  telefone    String
  data        DateTime
  horario     String   // Horário no formato HH:mm (ex: "14:00")
  status      String   @default("pendente") // pendente, confirmado, cancelado, recusado, concluido
  observacao  String?
  confirmadoAutomaticamente Boolean @default(false) // Se foi confirmado automaticamente (modo híbrido)
  dataConfirmacaoAutomatica DateTime? // Data/hora da confirmação automática (para calcular janela de 2h)
  formaPagamento String? // online, presencial - forma de pagamento escolhida pelo cliente
  
  // Relacionamento com cliente (opcional - pode ser agendamento sem cadastro)
  clienteId   String?
  clienteRel  Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  
  servico     Servico  @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  servicoId   String
  
  barbearia   Barbearia @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  barbeariaId String
  
  // Relacionamentos com profissionais e outros
  profissionais AgendamentoProfissional[]
  avaliacao     Avaliacao?
  pagamento     Pagamento?
  comissoes     ComissaoPaga[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Profissional da barbearia
model Profissional {
  id            String        @id @default(uuid())
  nome          String
  email         String?
  telefone      String
  foto          String?
  especialidades String[]     @default([]) // Array de strings
  comissaoTipo  String        @default("percentual") // percentual, fixo
  comissaoValor Float         @default(0)
  comissaoAssinatura Float    @default(0) // Comissão fixa por assinatura de cliente
  ativo         Boolean       @default(true)
  dataAdmissao  DateTime      @default(now())
  
  // Relacionamentos
  barbearia     Barbearia     @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  barbeariaId   String
  agendamentos  AgendamentoProfissional[]
  comissoes     ComissaoPaga[]
  clienteProfissional ClienteProfissional[]
  comissoesAssinatura ComissaoAssinatura[]
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// Relacionamento entre Agendamento e Profissional
model AgendamentoProfissional {
  id            String      @id @default(uuid())
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  agendamentoId String
  profissional  Profissional @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  profissionalId String
  
  createdAt     DateTime    @default(now())
  
  @@unique([agendamentoId, profissionalId])
}

// Produto da barbearia
model Produto {
  id            String      @id @default(uuid())
  nome          String
  descricao     String?
  categoria     String      // pomada, oleo, kit, outro
  preco         Float
  estoque       Int         @default(0)
  estoqueMinimo Int         @default(0)
  ativo         Boolean     @default(true)
  foto          String?
  
  barbearia     Barbearia  @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  barbeariaId   String
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// Promoção da barbearia
model Promocao {
  id            String      @id @default(uuid())
  nome          String
  tipo          String      // desconto_percentual, desconto_fixo, cashback, pontos
  valor         Float
  validoDe      DateTime
  validoAte     DateTime
  ativo         Boolean     @default(true)
  aplicavelA   String      @default("todos") // todos, servico, horario, cliente_vip
  servicoId    String?
  horarioInicio String?
  horarioFim   String?
  
  barbearia     Barbearia  @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  barbeariaId   String
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// Avaliação de agendamento
model Avaliacao {
  id                String      @id @default(uuid())
  agendamento       Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  agendamentoId     String      @unique
  cliente           Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId         String
  notaProfissional  Int         // 1-5
  notaAtendimento   Int         // 1-5
  notaAmbiente      Int         // 1-5
  comentario        String?
  resposta          String?     // Resposta do dono
  respondidoEm      DateTime?
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

// Notificação do sistema
model Notificacao {
  id          String      @id @default(uuid())
  tipo        String      // agendamento, pagamento, avaliacao, estoque, sistema
  titulo      String
  mensagem    String
  lida        Boolean     @default(false)
  data        DateTime    @default(now())
  urlAcao     String?
  labelAcao   String?
  
  // Relacionamento com barbearia (notificações do dono)
  barbearia   Barbearia?  @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  barbeariaId String?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// Pagamento de agendamento
model Pagamento {
  id            String      @id @default(uuid())
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  agendamentoId String      @unique
  valor         Float
  metodo        String      // pix, cartao_credito, cartao_debito, dinheiro, mercado_pago
  status        String      @default("pendente") // pago, pendente, reembolsado, cancelado, em_processamento
  taxaGateway   Float?      @default(0)
  dataPagamento DateTime?
  dataVencimento DateTime?
  
  // Campos específicos do Mercado Pago
  mercadoPagoPreferenceId String? // ID da preferência de pagamento criada no MP
  mercadoPagoPaymentId    String? // ID do pagamento quando aprovado
  mercadoPagoStatus       String? // approved, pending, rejected, cancelled, refunded
  mercadoPagoPaymentType  String? // credit_card, debit_card, ticket, bank_transfer, etc
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// Comissão paga ao profissional
model ComissaoPaga {
  id            String      @id @default(uuid())
  profissional  Profissional @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  profissionalId String
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  agendamentoId String
  valorComissao Float       // Valor da comissão calculada
  valorTotal    Float       // Valor total do agendamento
  porcentagem   Float       // Porcentagem aplicada
  pago          Boolean     @default(false) // Se a comissão foi paga
  dataPagamento DateTime?   // Data em que foi pago
  mesReferencia String       // Mês/ano de referência (ex: "2024-01")
  observacao    String?      // Observações sobre o pagamento
  
  barbearia     Barbearia   @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  barbeariaId   String
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@unique([agendamentoId, profissionalId])
  @@index([profissionalId, mesReferencia])
  @@index([barbeariaId, mesReferencia])
}

// Ticket de suporte (chamado aberto pelo cliente)
model TicketSuporte {
  id          String   @id @default(uuid())
  categoria   String   // agendamento, pagamento, fidelidade, conta, outro
  assunto     String
  mensagem    String
  status      String   @default("aberto") // aberto, em_andamento, resolvido, fechado
  prioridade  String   @default("media") // baixa, media, alta, urgente
  
  // Dados do cliente
  clienteId   String?
  cliente     Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  clienteNome String
  clienteEmail String
  
  // Resposta do admin
  resposta    String?
  respondidoPor String?
  respondidoEm DateTime?
  
  // Resolução
  resolvidoEm DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Plano de assinatura para clientes
model PlanoCliente {
  id            String      @id @default(uuid())
  nome          String      // Mensal, Trimestral, Semestral, Anual
  descricao     String?
  valor         Float       // Valor do plano
  duracaoMeses  Int         // Duração em meses (1, 3, 6, 12)
  beneficios    String[]    @default([]) // Array de benefícios
  ativo         Boolean     @default(true)
  
  // Relacionamento com barbearia (cada barbearia pode ter seus próprios planos)
  barbearia     Barbearia   @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  barbeariaId   String
  
  assinaturas   AssinaturaCliente[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// Assinatura de cliente
model AssinaturaCliente {
  id                String      @id @default(uuid())
  cliente           Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId         String      @unique
  plano             PlanoCliente @relation(fields: [planoId], references: [id])
  planoId           String
  profissional      Profissional @relation(fields: [profissionalId], references: [id], onDelete: SetNull)
  profissionalId   String?      // Profissional responsável pelo cliente
  
  status            String      @default("ativa") // ativa, suspensa, cancelada, vencida
  dataInicio        DateTime    @default(now())
  dataVencimento    DateTime
  proximoVencimento DateTime
  
  // Pagamento recorrente
  pagamentoRecorrente Boolean   @default(false)
  mercadoPagoSubscriptionId String? // ID da assinatura no Mercado Pago
  
  pagamentos        PagamentoAssinatura[]
  comissoes         ComissaoAssinatura[]
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

// Pagamento de assinatura de cliente
model PagamentoAssinatura {
  id                String      @id @default(uuid())
  assinatura        AssinaturaCliente @relation(fields: [assinaturaId], references: [id], onDelete: Cascade)
  assinaturaId      String
  
  valor             Float
  dataVencimento    DateTime
  dataPagamento     DateTime?
  status            String      @default("pendente") // pendente, paga, vencida, cancelada
  
  // Integração com gateway
  metodoPagamento   String?     // pix, boleto, cartao_credito, cartao_debito
  mercadoPagoPreferenceId String?
  mercadoPagoPaymentId    String?
  mercadoPagoStatus       String?
  
  // Dados do pagamento
  linkPagamento     String?
  qrCodePix         String?
  codigoBoleto       String?
  
  observacoes       String?
  
  comissoes         ComissaoAssinatura[]
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  @@index([assinaturaId, status])
  @@index([dataVencimento])
}

// Comissão de profissional por assinatura de cliente
model ComissaoAssinatura {
  id                String      @id @default(uuid())
  profissional      Profissional @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  profissionalId    String
  assinatura        AssinaturaCliente @relation(fields: [assinaturaId], references: [id], onDelete: Cascade)
  assinaturaId      String
  pagamento         PagamentoAssinatura @relation(fields: [pagamentoId], references: [id], onDelete: Cascade)
  pagamentoId       String
  
  valorComissao     Float       // Valor da comissão (fixo do profissional)
  valorTotal        Float       // Valor total do pagamento
  pago              Boolean     @default(false)
  dataPagamento     DateTime?
  mesReferencia     String      // Mês/ano de referência (ex: "2024-01")
  observacao        String?
  
  barbearia         Barbearia   @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  barbeariaId       String
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  @@unique([pagamentoId, profissionalId])
  @@index([profissionalId, mesReferencia])
  @@index([barbeariaId, mesReferencia])
}

// Relacionamento Cliente-Profissional (qual profissional atende qual cliente)
model ClienteProfissional {
  id            String      @id @default(uuid())
  cliente       Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId     String
  profissional  Profissional @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  profissionalId String
  
  ativo         Boolean     @default(true)
  dataInicio    DateTime    @default(now())
  dataFim       DateTime?   // Se null, ainda está ativo
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@unique([clienteId, profissionalId])
  @@index([clienteId])
  @@index([profissionalId])
}