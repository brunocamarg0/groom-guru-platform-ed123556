{
  "name": "groom-guru-backend",
  "version": "1.0.0",
  "description": "Backend API para Groom Guru Platform",
  "main": "dist/app.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "tsx scripts/setup-migrations.ts && node dist/app.js",
    "start:prod": "npm run build && npx prisma migrate deploy && node dist/app.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:push": "npx prisma db push --accept-data-loss",
    "prisma:studio": "npx prisma studio",
    "postinstall": "npx prisma generate",
    "criar-usuario-teste": "tsx scripts/criar-usuario-teste.ts",
    "criar-cliente-teste": "tsx scripts/criar-cliente-teste.ts",
    "listar-barbearias": "tsx scripts/listar-barbearias.ts",
    "testar-emailjs": "tsx scripts/testar-emailjs.ts",
    "testar-email-boas-vindas": "tsx scripts/testar-email-boas-vindas.ts",
    "corrigir-admin": "tsx scripts/corrigir-usuarios-admin.ts",
    "alterar-senha-dono": "tsx scripts/alterar-senha-dono.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@emailjs/nodejs": "^5.0.2",
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-session": "^1.18.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.12.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "prisma": "^5.20.0",
    "resend": "^6.7.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.14",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
